# ===============================
# Forex AI Signal Bot settings
# Copy this file to .env and fill only what you need.
# Never upload .env publicly.
# ===============================

# Comma-separated symbols. Use major FX pairs first.
SYMBOLS=EURUSD,GBPUSD,USDJPY,AUDUSD,USDCAD,USDCHF,NZDUSD
TIMEFRAME=1h
PERIOD=180d
SIGNAL_OUTPUT=latest_signals.csv
MIN_SIGNAL_STRENGTH=0.62

# Email alerts: Gmail App Password or other SMTP provider.
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_character_app_password
EMAIL_TO=receiver_email@gmail.com

# Broker execution is OFF by default. Keep it OFF until demo-tested.
BROKER=oanda
TRADE_EXECUTION_ENABLED=false
AUTO_TRADE_MODE=signal_only
LIVE_TRADING_ENABLED=false
LIVE_ACCOUNT_CONFIRMATION=no
I_UNDERSTAND_TRADING_RISK=no
OANDA_ENV=practice
OANDA_API_TOKEN=your_oanda_practice_token
OANDA_ACCOUNT_ID=your_oanda_practice_account_id
OANDA_UNITS=1000
CLOSE_OPPOSITE_POSITIONS=true

# Live-trading safety controls
ALLOWED_LIVE_SYMBOLS=EURUSD,GBPUSD,USDJPY
EXECUTION_MIN_SIGNAL_STRENGTH=0.65
REQUIRE_STOP_LOSS=true
REQUIRE_TAKE_PROFIT=true
BLOCK_LOW_QUALITY_SESSIONS=true
MAX_DAILY_LOSS_PCT=2.0
MAX_INTRADAY_DRAWDOWN_PCT=3.0
MAX_TRADES_PER_DAY=3
MAX_TRADES_PER_SYMBOL_PER_DAY=1
MAX_OPEN_TRADES=2
COOLDOWN_MINUTES=60
SPREAD_FILTER_ENABLED=true
MAX_SPREAD_PIPS=2.5
ACCOUNT_RISK_STRICT=true
TRADE_JOURNAL_FILE=trade_journal.csv
RISK_STATE_FILE=risk_state.json

# Optional risk-percent position sizing. Leave false while learning.
USE_RISK_POSITION_SIZING=false
RISK_PER_TRADE_PCT=0.5
MAX_UNITS=1000
MIN_UNITS=1

# Optional news filter. Create news_blackout.csv first if enabled.
NEWS_FILTER_ENABLED=false
NEWS_FILTER_STRICT=true
NEWS_BLACKOUT_FILE=news_blackout.csv
NEWS_BLACKOUT_MINUTES=45
NEWS_BLOCK_IMPACTS=High

# Dashboard/API
API_SHARED_SECRET=change_me_optional
